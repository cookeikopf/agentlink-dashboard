# Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/agentlink?schema=public"

# Blockchain
RPC_URL="https://sepolia.base.org"
PRIVATE_KEY="" # Your deployer private key - NEVER commit this!
USDC_CONTRACT="0x036CbD53842c5426634e7929541eC2318f3dCF7e"

# Contracts (After deployment)
AGENT_REPUTATION_CONTRACT=""
PAYMENT_ROUTER_CONTRACT=""

# API
API_PORT=3000
API_HOST="0.0.0.0"
JWT_SECRET="" # Generate with: openssl rand -base64 32

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring
SENTRY_DSN=""
LOG_LEVEL="info"

# Treasury
TREASURY_ADDRESS=""
PLATFORM_FEE_PERCENT=100 # 1% = 100 basis points
